# Required for LLM extraction and query answering
ANTHROPIC_API_KEY=sk-ant-...

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_TASK_QUEUE=care-passport

# Knowledge store backend: "markdown" (default), "stub" (no API keys), or "graphiti"
KNOWLEDGE_STORE=markdown

# Root directory for patient data (markdown files)
DATA_ROOT=/data/patients

# Kuzu graph DB path (only used when KNOWLEDGE_STORE=graphiti)
KUZU_DB_PATH=/tmp/care-passport-kuzu

# Optional — only needed when KNOWLEDGE_STORE=graphiti
VOYAGE_API_KEY=

# Optional — persistent Cloudflare named tunnel (recommended for demo day).
# Get the token from: Zero Trust dashboard → Networks → Tunnels → Create a tunnel → Cloudflared.
# Configure the public hostname in the same dashboard pointing to http://api:8000.
# If unset, the stack falls back to an ephemeral *.trycloudflare.com URL each `make up`.
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_HOSTNAME=
