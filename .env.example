# Vapi server-side (private — never expose to browser)
VAPI_API_KEY=your_vapi_private_key_here
ASSISTENT_ID=your_vapi_assistant_id_here
VAPI_TOOL_ID=your_vapi_tool_id_here

# Care Passport: /api/care-passport proxy uses NEXT_PUBLIC_* first, then LOCAL_* (fallback).
# Public tunnel / Vapi variableValues (optional). Leave empty for local-only → proxy uses LOCAL_*.
NEXT_PUBLIC_CARE_PASSPORT_API_BASE_URL=https://passport.curiloo.com
# Local Docker backend (cd ideas/care-passport/code && make up)
LOCAL_CARE_PASSPORT_API_BASE_URL=http://localhost:8000
# Set to "true" to use mockCarePassportApi instead of the proxy.
# NEXT_PUBLIC_CARE_PASSPORT_USE_MOCK=
