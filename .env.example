# Vapi server-side (private — never expose to browser)
VAPI_API_KEY=your_vapi_private_key_here
ASSISTENT_ID=your_vapi_assistant_id_here
VAPI_TOOL_ID=your_vapi_tool_id_here

# Care Passport API
CARE_PASSPORT_URL=https://passport.curiloo.com
# Shared secret — Vapi sends this as x-vapi-secret; care passport API must validate it
VAPI_KB_SECRET=your_secret_here

# Care Passport API proxy (used by app/api/care-passport/[...path]/route.ts)
# Point this at the backend (e.g. http://localhost:8000 for local docker compose,
# or the cloudflared tunnel URL).
CARE_PASSPORT_API_BASE_URL=http://localhost:8000
# Bearer token — must match the backend's API_AUTH_TOKEN (in backend/.env).
API_AUTH_TOKEN=replace-me
